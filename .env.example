# docs_ci — provider API keys
#
# Set the variable that matches the --provider you intend to use.
# docs-ci reads these from the environment at startup; copy this file to
# `.env` and fill in the value(s) you need, or export them in your shell.

# Anthropic (default provider, --provider anthropic)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenRouter (--provider openrouter)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# NVIDIA build.nvidia.com (--provider nvidia)
# https://build.nvidia.com — generate a key from any model's page
NVIDIA_API_KEY=
